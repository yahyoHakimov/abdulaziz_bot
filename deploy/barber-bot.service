[Unit]
Description=Barber Reminder Telegram Bot
After=network.target

[Service]
Type=simple
User=barber
Group=barber
WorkingDirectory=/opt/abdulaziz_bot
ExecStart=/opt/abdulaziz_bot/venv/bin/python main.py
Restart=always
RestartSec=5
# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/abdulaziz_bot

[Install]
WantedBy=multi-user.target
