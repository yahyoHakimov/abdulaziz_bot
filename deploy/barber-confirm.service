[Unit]
Description=Barber Bot — evening confirmations
After=network.target

[Service]
Type=oneshot
User=barber
Group=barber
WorkingDirectory=/opt/abdulaziz_bot
ExecStart=/opt/abdulaziz_bot/venv/bin/python cron/confirm.py
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/abdulaziz_bot
